<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('./partials/header') %>

    <title>Add new Blogs</title>
</head>

<body>

  <%- include('./partials/navbar') %>

    <main class="page-shell">
      <section class="hero">
        <h1>Create a New Story</h1>
        <p>Craft your post with a striking cover and meaningful content.</p>
      </section>

      <section class="panel">
        <form method="post" action="/blog" enctype="multipart/form-data">

          <div class="mb-3">
            <label for="InputFile" class="form-label">Cover Image</label>
            <input type="file" class="form-control" name="coverImage" id="InputFile" aria-describedby="coverImage" required>
          </div>
          <div class="mb-3">
            <label for="InputTitle" class="form-label">Title</label>
            <input type="text" class="form-control" name="title" id="InputTitle" aria-describedby="title" required>
          </div>

          <div class="mb-3">
            <label for="floatingTextarea" class="form-label">Body</label>
            <textarea class="form-control" placeholder="Write something beautiful here..." id="floatingTextarea" name="body" rows="9" required></textarea>
          </div>

          <div class="mb-1">
            <button type="submit" class="btn btn-classy">Publish Blog</button>
          </div>
        </form>
      </section>
    </main>

    <%- include('./partials/script') %>
</body>

</html>