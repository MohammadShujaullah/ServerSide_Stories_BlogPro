<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('./partials/header') %>

    <title>Home page</title>
</head>

<body>

  <%- include('./partials/navbar') %>
    <main class="page-shell">
      <section class="hero">
        <h1>Write. Read. Share timeless stories.</h1>
        <p>ServerSide Stories is your elegant corner for thoughtful writing and meaningful conversations.</p>
      </section>

      <% if (blogs && blogs.length) { %>
        <section class="card-grid">
          <% blogs.forEach(blog => { %>
            <article class="story-card">
              <img src="/<%= blog.coverImageURL %>" alt="<%= blog.title %>">
              <div class="card-body">
                <h5 class="card-title"><%= blog.title %></h5>
                <a href="/blog/<%= blog._id %>" class="btn btn-classy">Read Story</a>
              </div>
            </article>
          <% }) %>
        </section>
      <% } else { %>
        <section class="panel text-center py-4">
          <h3 class="form-title">No stories yet</h3>
          <p class="meta">Start your first blog and make this space alive.</p>
          <a href="/blog/add-new" class="btn btn-classy mt-2">Create First Blog</a>
        </section>
      <% } %>
    </main>


    <%- include('./partials/script') %>
</body>

</html>